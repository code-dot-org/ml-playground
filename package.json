{
  "name": "@code-dot-org/ml-playground",
  "version": "0.0.47",
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/code-dot-org/ml-playground.git"
  },
  "jest": {
    "moduleNameMapper": {
      ".+\\.(bin|jpg|jpeg|png|mp3|ogg|wav|gif)$": "identity-obj-proxy",
      "^@public(.*)$": "<rootDir>/public/$1"
    }
  },
  "author": "",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=22.21",
    "npm": ">=3.10.8"
  },
  "scripts": {
    "build": "webpack --mode production",
    "start": "yarn run dev",
    "dev": "webpack-dev-server --mode development --static public --host 0.0.0.0 --allowed-hosts all",
    "lint": "eslint --ext .js,.jsx src",
    "test": "yarn run lint && jest",
    "test:unit": "jest ./test/unit/*.js",
    "preversion": "yarn install && yarn run test",
    "version": "yarn run build",
    "postversion": "git push && git push --tags && yarn publish"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "babel-jest": "29",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "11",
    "core-js": "^3",
    "css-loader": "^7.1.4",
    "eslint": "8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "29",
    "messageformat": "2.3.0",
    "ml-knn": "^3.0.0",
    "query-string": "4.1.0",
    "react": "18",
    "react-dom": "18",
    "react-papaparse": "^3.8.0",
    "react-redux": "9",
    "redux": "^4.0.5",
    "style-loader": "^4.0.0",
    "webpack": "5",
    "webpack-bundle-analyzer": "^3.6.0",
    "webpack-cli": "5",
    "webpack-dev-server": "5"
  },
  "files": [
    "dist/**/!(mainDev.js)",
    "i18n/mlPlayground.json",
    "public/datasets/*.json",
    "public/*.json"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.25",
    "@fortawesome/free-solid-svg-icons": "^5.11.2",
    "@fortawesome/react-fontawesome": "^0.1.7",
    "chart.js": "^2.9.4",
    "react-chartjs-2": "^2.11.1",
    "reselect": "^4.0.0"
  }
}
